{
  "expo": {
    "name": "SafeHome Mobile",
    "slug": "safehome-iot-mobile",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "safehome",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.safehome.mobile"
    },
    "android": {
      "package": "com.safehome.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f3b44"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0f3b44"
        }
      ]
    ]
  }
}
